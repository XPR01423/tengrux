#############################################
#####   Pkg-Config file for libxcrypt   #####
#############################################

prefix=/system
exec_prefix=${prefix}

libdir=/system/lib64
includedir=${prefix}/include

Name: libxcrypt
Version: 4.5.2
Description: Extended crypt library for DES, MD5, Blowfish and others
Libs: -L${libdir} -lcrypt
Cflags: -I${includedir}
